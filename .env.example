NEXT_PUBLIC_ANALYTICS_MODE=off
NEXT_PUBLIC_HARDWARE_MODE_ENABLED=true
NEXT_PUBLIC_REGION_NOTICE=us_eu_child

# ---------------------------------------------------------------------------
# Cloudflare D1 database binding
# ---------------------------------------------------------------------------
# When deploying to Cloudflare Pages the D1 database is bound automatically
# via wrangler.toml — you do NOT need to set DB here.
#
# For local development with `wrangler pages dev` (recommended):
#   wrangler d1 execute arduino-quest-db --local \
#     --file=db/migrations/0001_create_learner_progress.sql
#   wrangler pages dev -- pnpm dev
#
# When running `pnpm dev` directly (plain Next.js, no D1 available):
#   The API routes detect the missing binding and return sensible defaults,
#   so the app remains fully functional using localStorage only.
# DB=          <-- injected automatically by Cloudflare; never set manually

